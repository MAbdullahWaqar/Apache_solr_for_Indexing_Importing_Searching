# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.env
.pytest_cache/

# --- Node ---
node_modules/
npm-debug.log
yarn-error.log

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# --- Solr / runtime ---
# Ignore an unpacked Solr installation if developers extract the tarball here,
# but explicitly keep our project's solr-config/ directory.
solr-[0-9]*/
solr-*.tgz
solr-*.zip
!solr-config/
*.log
logs/

# --- Build / Dist ---
dist/
build/
*.bak

# --- Word lockfiles ---
~$*.docx
